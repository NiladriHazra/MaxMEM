{
  "name": "@bytehumi/maxmem",
  "version": "0.1.1",
  "description": "Local-first handoff capsules for Codex, Claude Code, and OpenCode.",
  "keywords": [
    "agents",
    "ai",
    "claude",
    "codex",
    "handoff",
    "mcp",
    "memory",
    "opencode"
  ],
  "homepage": "https://github.com/NiladriHazra/MaxMEM#readme",
  "bugs": {
    "url": "https://github.com/NiladriHazra/MaxMEM/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NiladriHazra/MaxMEM.git"
  },
  "bin": {
    "maxmem": "bin/maxmem"
  },
  "files": [
    "bin",
    "src",
    "README.md",
    "LICENSE",
    "assets"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun scripts/build.ts",
    "dev": "bun bin/maxmem",
    "format": "bunx oxfmt --write .",
    "lint": "bunx oxlint .",
    "postinstall": "bun bin/maxmem --help >/dev/null 2>&1 || true",
    "prepack": "bun run build",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "oxfmt": "latest",
    "oxlint": "latest",
    "typescript": "latest"
  }
}
