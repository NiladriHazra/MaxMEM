{
  "name": "maxmem",
  "version": "0.1.0",
  "description": "Local-first handoff capsules for Codex, Claude Code, and OpenCode.",
  "bin": {
    "maxmem": "./bin/maxmem"
  },
  "files": [
    "bin",
    "src",
    "README.md",
    "assets"
  ],
  "type": "module",
  "publishConfig": {
